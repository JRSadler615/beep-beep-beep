# In production these are injected by Doppler; locally, copy to .env.

# Supabase (Database / Auth via GoTrue)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
# Service-role key — server-only, bypasses RLS. NEVER expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# JWT secret from Supabase project settings (Auth -> JWT keys). Used to verify
# the bearer token the SPA sends.
SUPABASE_JWT_SECRET="your-jwt-secret"

# Frontend origin (for CORS) and where OAuth redirects back to.
# PROD HOSTNAME: set to the deployed SPA origin (e.g. https://jrsadler.com).
# Used for the CORS allow-list AND as the base for the post-OAuth redirect
# (FRONTEND_URL/ebay-connect?success=true), so it must be the URL the user's
# browser actually loads the SPA from.
FRONTEND_URL="http://localhost:3000"

# eBay API
EBAY_SANDBOX="false"
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
# The RuName value itself does NOT change between dev and prod.
# PROD HOSTNAME: but the RuName's "auth accepted URL" registered in the eBay
# Developer Portal must point at the backend's public callback. In dev that's
# the Cloudflare Tunnel host (https://<dev-tunnel>/api/ebay/callback); in prod
# update it to the production backend (e.g. https://api.jrsadler.com/api/ebay/callback).
EBAY_RUNAME=""
EBAY_SCOPE="https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory.readonly https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.marketing.readonly https://api.ebay.com/oauth/api_scope/sell.marketing https://api.ebay.com/oauth/api_scope/sell.account.readonly https://api.ebay.com/oauth/api_scope/sell.account"
EBAY_MARKETPLACE_ID="EBAY_US"

# Verbose eBay debug logging (never logs tokens)
EBAY_DEBUG="false"

# Observability (optional)
SENTRY_DSN=""
