# Supabase project (Database / Auth via GoTrue)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# FastAPI backend base URL.
# Leave empty to use same-origin relative /api paths (recommended in
# production behind Cloudflare). In local dev, vite.config.ts proxies /api
# to VITE_API_PROXY (default http://localhost:8000).
VITE_API_URL=""

# Dev-only: where Vite proxies /api requests (the local FastAPI server)
VITE_API_PROXY="http://localhost:8000"
